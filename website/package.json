{
  "name": "uncost-website",
  "private": true,
  "description": "Static site scaffold for uncost.org. Placeholder templates only; design and copy arrive via the governed design handoff.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve",
    "audit:built": "python3 ../scripts/audit_website.py --built dist",
    "report:a11y": "node scripts/a11y-report.cjs",
    "report:lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.4",
    "markdown-it": "^14.0.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "html-validate": "^9.7.1",
    "pa11y": "^9.1.1"
  }
}
